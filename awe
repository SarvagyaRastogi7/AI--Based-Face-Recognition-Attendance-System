<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Briefing – {{ company_name }}</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          Arial, sans-serif;
        background: #f9fafb;
        margin: 0;
        padding: 24px 32px 40px;
        color: #111827;
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12);
        padding: 28px 32px 36px;
      }

      h1 {
        margin-top: 0;
        font-size: 24px;
        margin-bottom: 4px;
      }

      .subtitle {
        margin-bottom: 16px;
        font-size: 13px;
        color: #6b7280;
      }

      h2 {
        margin-top: 18px;
        margin-bottom: 6px;
        font-size: 18px;
        color: #1d4ed8;
        border-bottom: 1px solid #e5e7eb;
        padding-bottom: 3px;
      }

      p {
        margin: 4px 0;
        line-height: 1.5;
      }

      ul {
        margin: 4px 0 4px 20px;
      }

      li {
        margin: 2px 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Client Briefing – {{ company_name }}</h1>
      <div class="subtitle">
        Generated briefing based on SmartInsights data{% if meeting_context %}
        for: <strong>{{ meeting_context }}</strong>{% endif %}.
      </div>

      <h2>Executive Summary</h2>
      {{ sections.executive_summary | safe }}

      <h2>Background of the Prospect</h2>
      {{ sections.prospect_background | safe }}

      <h2>Standard Information from Businesses</h2>
      {{ sections.standard_information | safe }}

      <h2>Potential Areas of Engagement and Talk Points</h2>
      {{ sections.engagement_opportunities | safe }}

      <h2>Strategic Initiatives and Focus Areas</h2>
      {{ sections.strategic_initiatives | safe }}

      <h2>Client Overview</h2>
      {{ sections.client_overview | safe }}

      <h2>Recent and Relevant News</h2>
      {{ sections.recent_news | safe }}
    </div>
  </body>
</html>

