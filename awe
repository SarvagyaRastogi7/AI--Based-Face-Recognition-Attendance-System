from functools import lru_cache
import os
from dataclasses import dataclass
from typing import Optional


@dataclass
class Settings:
    """
    Minimal settings loader using plain environment variables.
    No pydantic dependency needed, so this works with any version.
    """

    # General
    app_name: str = "RAG Briefing Generator"

    # Azure OpenAI / Azure Models via openai SDK
    azure_openai_endpoint: Optional[str] = os.getenv("AZURE_OPENAI_ENDPOINT")
    azure_openai_api_key: Optional[str] = os.getenv("AZURE_OPENAI_API_KEY")
    azure_openai_deployment: Optional[str] = os.getenv("AZURE_OPENAI_DEPLOYMENT")
    azure_openai_api_version: str = os.getenv(
        "AZURE_OPENAI_API_VERSION", "2024-10-21"
    )

    # Database (Oracle or other)
    db_dsn: Optional[str] = os.getenv("DB_DSN")
    db_user: Optional[str] = os.getenv("DB_USER")
    db_password: Optional[str] = os.getenv("DB_PASSWORD")
    db_host: Optional[str] = os.getenv("DB_HOST")
    db_port: int = int(os.getenv("DB_PORT", "1521"))
    db_service: Optional[str] = os.getenv("DB_SERVICE")

    # Web search
    search_api_key: Optional[str] = os.getenv("SEARCH_API_KEY")
    search_endpoint: Optional[str] = os.getenv("SEARCH_ENDPOINT")


@lru_cache(maxsize=1)
def get_settings() -> Settings:
    return Settings()

