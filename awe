"""
Oracle service wired to Corporate Relationship Manager Dashboard (RMDB) tables.

Tables used:
- MV_DIM_LH_CUST_IB_GKAP: central customer (lookup by name; feeds Background, Client Overview)
- MV_USER_ACCESS: user roles per customer (Standard Information)
- DIM_LH_IB_GKAP_REPORT: KAP reports (Standard Information)
- FCT_LH_IB_GKAP_WALLET_DETAILS: wallet sizes / values (Standard Information, Client Overview)
- FCT_LH_IB_GKAP_FINANCIAL_RATIO: financial ratios (Strategic Initiatives, Client Overview)
- FCT_LH_IB_GKAP_ISSUE_CONSTRAINT: issues/constraints (Engagement, Strategic)
"""

from __future__ import annotations

from typing import Any, Dict, List

import oracledb

from app.config import get_settings


def _row_to_dict(cur: Any, row: tuple) -> Dict[str, Any]:
    if not row:
        return {}
    columns = [desc[0].lower() for desc in cur.description]
    return dict(zip(columns, row))


class OracleService:
    """
    Fetches data from RMDB tables. Lookup by CUSTOMER_NAME in MV_DIM_LH_CUST_IB_GKAP;
    other tables joined via CUSTOMER_NUMBER / CUSTOMER_ID.
    """

    def __init__(self) -> None:
        self._settings = get_settings()

    def _connect(self) -> oracledb.Connection:
        if self._settings.db_dsn:
            dsn = self._settings.db_dsn
        else:
            if not (
                self._settings.db_host
                and self._settings.db_service
                and self._settings.db_user
            ):
                raise RuntimeError(
                    "Database settings missing. Set DB_DSN or "
                    "DB_HOST, DB_SERVICE, DB_USER (and DB_PORT, DB_PASSWORD)."
                )
            dsn = oracledb.makedsn(
                self._settings.db_host,
                int(self._settings.db_port or 1521),
                service_name=self._settings.db_service,
            )
        return oracledb.connect(
            user=self._settings.db_user,
            password=self._settings.db_password,
            dsn=dsn,
        )

    def get_client_profile(self, company_name: str) -> Dict[str, Any]:
        """
        Fetch one customer from MV_DIM_LH_CUST_IB_GKAP by CUSTOMER_NAME.
        Used for: Background of the Prospect, Client Overview, and as key for other tables.
        """
        query = """
            SELECT
                MDM_ID,
                CUSTOMER_NUMBER,
                CUSTOMER_UID,
                CUSTOMER_NAME,
                CODED_CUSTOMER_NAME,
                RM_EMP_ID,
                RM_NAME,
                RM_TYPE,
                RM_LOCATION,
                CUSTOMER_SEGMENT,
                CUSTOMER_SUB_SEGMENT,
                CUST_CATEGORY,
                GROUP_NAME,
                GROUP_ID,
                GROUP_KEY,
                CUSTOMER_STATUS,
                CUSTOMER_VISIBLE_FLAG,
                CUSTOMER_CREATION_DATE,
                LOAD_DATE,
                FROM_DATE,
                TO_DATE
            FROM MV_DIM_LH_CUST_IB_GKAP
            WHERE UPPER(TRIM(CUSTOMER_NAME)) = UPPER(TRIM(:name))
            AND (CUSTOMER_VISIBLE_FLAG = 1 OR CUSTOMER_VISIBLE_FLAG IS NULL)
            AND ROWNUM = 1
        """
        with self._connect() as conn:
            with conn.cursor() as cur:
                cur.execute(query, {"name": company_name})
                row = cur.fetchone()
                return _row_to_dict(cur, row) if row else {}

    def get_user_access(self, customer_number: str) -> List[Dict[str, Any]]:
        """MV_USER_ACCESS: roles and access for this customer. For Standard Information."""
        query = """
            SELECT FGB_ID, CUSTOMER_NUMBER, ROLE, BANKING_TYPE_CUST
            FROM MV_USER_ACCESS
            WHERE CUSTOMER_NUMBER = :customer_number
        """
        with self._connect() as conn:
            with conn.cursor() as cur:
                cur.execute(query, {"customer_number": customer_number})
                rows = cur.fetchall()
                return [_row_to_dict(cur, row) for row in rows]

    def get_kap_reports(self, customer_id: str) -> List[Dict[str, Any]]:
        """DIM_LH_IB_GKAP_REPORT: KAP reports for this customer. For Standard Information."""
        query = """
            SELECT KAP_REPORT_ID, CUSTOMER_ID, GROUP_ORR, BANKING_TYPE
            FROM DIM_LH_IB_GKAP_REPORT
            WHERE CUSTOMER_ID = :customer_id
        """
        with self._connect() as conn:
            with conn.cursor() as cur:
                cur.execute(query, {"customer_id": customer_id})
                rows = cur.fetchall()
                return [_row_to_dict(cur, row) for row in rows]

    def get_wallet_details(self, customer_id: str) -> List[Dict[str, Any]]:
        """FCT_LH_IB_GKAP_WALLET_DETAILS: wallet sizes and values. For Standard Information, Client Overview."""
        query = """
            SELECT
                KAP_REPORT_ID,
                CUSTOMER_ID,
                BANKING_TYPE,
                CLIENT_WALLET_SIZE,
                CLIENT_WALLET_SIZE_NRM,
                CLIENT_WALLET_SIZE_GRM,
                VALUE_PY2,
                VALUE_PY1,
                VALUE_CY
            FROM FCT_LH_IB_GKAP_WALLET_DETAILS
            WHERE CUSTOMER_ID = :customer_id
        """
        with self._connect() as conn:
            with conn.cursor() as cur:
                cur.execute(query, {"customer_id": customer_id})
                rows = cur.fetchall()
                return [_row_to_dict(cur, row) for row in rows]

    def get_financial_ratios(self, customer_id: str) -> List[Dict[str, Any]]:
        """FCT_LH_IB_GKAP_FINANCIAL_RATIO: ratios and trends. For Strategic Initiatives, Client Overview."""
        query = """
            SELECT
                KAP_REPORT_ID,
                CUSTOMER_ID,
                KPI_DESCRIPTION,
                VALUE_PY4,
                VALUE_PY3,
                VALUE_PY2,
                VALUE_PY1,
                VALUE_CY
            FROM FCT_LH_IB_GKAP_FINANCIAL_RATIO
            WHERE CUSTOMER_ID = :customer_id
        """
        with self._connect() as conn:
            with conn.cursor() as cur:
                cur.execute(query, {"customer_id": customer_id})
                rows = cur.fetchall()
                return [_row_to_dict(cur, row) for row in rows]

    def get_issues_constraints(self, customer_id: str) -> List[Dict[str, Any]]:
        """FCT_LH_IB_GKAP_ISSUE_CONSTRAINT: issues/constraints. For Engagement, Strategic Initiatives."""
        query = """
            SELECT KAP_REPORT_ID, CUSTOMER_ID, ISSUE_CONSTRAINT_TYPE, DESCRIPTION, STATUS
            FROM FCT_LH_IB_GKAP_ISSUE_CONSTRAINT
            WHERE CUSTOMER_ID = :customer_id
        """
        try:
            with self._connect() as conn:
                with conn.cursor() as cur:
                    cur.execute(query, {"customer_id": customer_id})
                    rows = cur.fetchall()
                    return [_row_to_dict(cur, row) for row in rows]
        except oracledb.Error:
            # Column names may differ; return empty if table/columns not present
            return []

    def get_section_data(self, company_name: str) -> Dict[str, Any]:
        """
        Single entry point: fetch profile by company name, then all RMDB data
        needed for each briefing section. Returns a dict with:
        - client_profile: from MV_DIM_LH_CUST_IB_GKAP (Background, Client Overview)
        - user_access: Standard Information
        - kap_reports: Standard Information
        - wallet_details: Standard Information, Client Overview
        - financial_ratios: Strategic Initiatives, Client Overview
        - issues_constraints: Engagement, Strategic Initiatives
        """
        profile = self.get_client_profile(company_name)
        if not profile:
            return {"client_profile": {}, "user_access": [], "kap_reports": [], "wallet_details": [], "financial_ratios": [], "issues_constraints": []}

        # Use CUSTOMER_NUMBER for MV_USER_ACCESS; same value often used as CUSTOMER_ID in DIM/FCT
        customer_number = profile.get("customer_number") or profile.get("customer_uid") or ""
        customer_id = str(profile.get("customer_id") or customer_number)

        return {
            "client_profile": profile,
            "user_access": self.get_user_access(str(customer_number)),
            "kap_reports": self.get_kap_reports(customer_id),
            "wallet_details": self.get_wallet_details(customer_id),
            "financial_ratios": self.get_financial_ratios(customer_id),
            "issues_constraints": self.get_issues_constraints(customer_id),
        }
